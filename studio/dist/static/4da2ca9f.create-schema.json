[
  {
    "fields": [
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "title",
        "type": "string"
      },
      {
        "options": {
          "hotspot": true
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "image",
        "type": "image"
      },
      {
        "description": "Describe the painting for screen readers and SEO. e.g. \"57th Street Overpass — Oil on Canvas by Kathleen Eaton\"",
        "name": "altText",
        "type": "string"
      },
      {
        "placeholder": "Oil on Canvas",
        "name": "medium",
        "type": "string"
      },
      {
        "placeholder": "24\"h × 36\"w",
        "name": "dimensions",
        "type": "string"
      },
      {
        "description": "Leave blank if not for sale.",
        "name": "price",
        "type": "number"
      },
      {
        "options": {
          "list": [
            {
              "title": "Sold",
              "value": "sold"
            },
            {
              "title": "Urban Landscapes",
              "value": "urban-landscapes"
            },
            {
              "title": "Suburbia",
              "value": "suburbia"
            },
            {
              "title": "Posters",
              "value": "posters"
            }
          ]
        },
        "name": "category",
        "type": "string"
      },
      {
        "options": {
          "dateFormat": "YYYY-MM-DD",
          "timeStep": 60
        },
        "description": "Original upload date from WordPress. Controls gallery order — most recent first.",
        "name": "publishedAt",
        "type": "datetime",
        "title": "Upload Date"
      }
    ],
    "name": "painting",
    "type": "document"
  },
  {
