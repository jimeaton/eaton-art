---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import { sanityClient } from '../../lib/sanity';
import { ptToHtml } from '../../lib/portableText';

const page = await sanityClient.fetch(
  `*[_type == "midwayMuralsPage"][0]{ heading, body[]{ ..., asset-> } }`
);

const heading  = page?.heading ?? 'Midway Murals';
const bodyHtml = page?.body    ? ptToHtml(page.body) : '';
---

<Layout title="Midway Murals — Kathleen Eaton">
  <Header currentPath="/collections-awards/" />

  <div id="main">
    <div class="wrap">
      <div class="middle clearfix">

        <main id="content">
          <div class="post page">
            <h1>{heading}</h1>

            <div class="page-body">
              {bodyHtml
                ? <Fragment set:html={bodyHtml} />
                : <p>Content coming soon.</p>
              }
            </div>
          </div>
        </main>

        <Sidebar />

      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .page-body {
    margin-top: 20px;
  }
</style>
