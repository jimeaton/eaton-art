---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { sanityClient } from '../lib/sanity';
import { ptToHtml } from '../lib/portableText';

const page = await sanityClient.fetch(
  `*[_type == "collectionsPage"][0]{ heading, columnLeft, columnRight }`
);

const heading      = page?.heading      ?? 'Collections & Awards';
const leftHtml     = page?.columnLeft   ? ptToHtml(page.columnLeft)  : '';
const rightHtml    = page?.columnRight  ? ptToHtml(page.columnRight) : '';
---

<Layout title="Collections & Awards — Kathleen Eaton">
  <Header currentPath="/collections-awards/" />

  <div id="main">
    <div class="wrap">
      <div class="middle clearfix">

        <main id="content">
          <div class="post page">
            <h1>{heading}</h1>

            <div class="collections-columns">
              <div class="collections-col">
                {leftHtml
                  ? <Fragment set:html={leftHtml} />
                  : <p>Content coming soon.</p>
                }
              </div>
              <div class="collections-col">
                {rightHtml && <Fragment set:html={rightHtml} />}
              </div>
            </div>
          </div>
        </main>

        <Sidebar />

      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .collections-columns {
    display: flex;
    gap: 40px;
    margin-top: 20px;
  }

  .collections-col {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 600px) {
    .collections-columns {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
